---
import "@/styles/global.css";
import AnalyticsBootstrap from "@/components/AnalyticsBootstrap";
import { SEO_CONFIG } from "@/lib/seo-config";

interface SchemaValue {
  [key: string]: unknown;
}

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  keywords?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  twitterCard?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
  noindex?: boolean;
  schemas?: SchemaValue[];
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  keywords,
  ogTitle = title,
  ogDescription = description,
  ogImage = SEO_CONFIG.defaultOgImage,
  ogType = "website",
  twitterCard = "summary_large_image",
  twitterTitle = ogTitle,
  twitterDescription = ogDescription,
  twitterImage = ogImage,
  noindex = false,
  schemas = [],
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, SEO_CONFIG.siteUrl);
canonicalUrl.hash = "";
canonicalUrl.search = "";

if (canonicalUrl.pathname !== "/") {
  canonicalUrl.pathname = canonicalUrl.pathname.replace(/\/+$/, "");
}

const robots = noindex
  ? "noindex, nofollow"
  : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1";
---

<!doctype html>
<html lang="de" class="w-full h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content={robots} />
    <meta name="author" content="energievergleich.shop" />
    <link rel="canonical" href={canonicalUrl.toString()} />

    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SEO_CONFIG.siteName} />
    <meta property="og:locale" content="de_DE" />

    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={twitterTitle} />
    <meta name="twitter:description" content={twitterDescription} />
    <meta name="twitter:image" content={twitterImage} />

    {SEO_CONFIG.googleSearchConsoleVerification && (
      <meta
        name="google-site-verification"
        content={SEO_CONFIG.googleSearchConsoleVerification}
      />
    )}

    {schemas.map((schema, index) => (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(schema)}
        data-schema-index={index}
      />
    ))}
    <script is:inline define:vars={{ canonicalHref: canonicalUrl.toString() }}>
      (() => {
        const canonicalLinks = Array.from(document.head.querySelectorAll('link[rel="canonical"]'));
        if (canonicalLinks.length === 0) {
          const link = document.createElement("link");
          link.setAttribute("rel", "canonical");
          link.setAttribute("href", canonicalHref);
          document.head.appendChild(link);
        } else {
          canonicalLinks.forEach((link, index) => {
            if (index === 0) {
              link.setAttribute("href", canonicalHref);
              return;
            }
            link.remove();
          });
        }

        const ogUrlMetas = Array.from(document.head.querySelectorAll('meta[property="og:url"]'));
        if (ogUrlMetas.length === 0) {
          const meta = document.createElement("meta");
          meta.setAttribute("property", "og:url");
          meta.setAttribute("content", canonicalHref);
          document.head.appendChild(meta);
        } else {
          ogUrlMetas.forEach((meta, index) => {
            if (index === 0) {
              meta.setAttribute("content", canonicalHref);
              return;
            }
            meta.remove();
          });
        }
      })();
    </script>
    <slot name="head" />
  </head>
  <body class="w-full h-full">
    <AnalyticsBootstrap client:load measurementId={SEO_CONFIG.googleAnalyticsId} />
    <slot />
  </body>
</html>
