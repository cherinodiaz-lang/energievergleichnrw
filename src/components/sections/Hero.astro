---
interface Props {
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  backgroundImage?: string;
}

const {
  title,
  subtitle,
  ctaText = 'Jetzt vergleichen',
  ctaLink = '#vergleich',
  secondaryCtaText,
  secondaryCtaLink,
  backgroundImage
} = Astro.props;
---

<section class="hero-section relative overflow-hidden">
  <!-- Background Gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-blue-600 via-blue-700 to-blue-900">
    {backgroundImage && (
      <div class="absolute inset-0 opacity-10">
        <img src={backgroundImage} alt="" class="w-full h-full object-cover" loading="eager" />
      </div>
    )}
  </div>
  
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-1/2 -right-1/2 w-full h-full bg-blue-500 rounded-full opacity-10 blur-3xl animate-pulse"></div>
    <div class="absolute -bottom-1/2 -left-1/2 w-full h-full bg-blue-400 rounded-full opacity-10 blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
  </div>
  
  <!-- Content -->
  <div class="relative container mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-36">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 animate-fade-in-up">
        {title}
      </h1>
      
      <!-- Subtitle -->
      <p class="text-xl sm:text-2xl text-blue-100 mb-10 animate-fade-in-up" style="animation-delay: 0.2s;">
        {subtitle}
      </p>
      
      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-in-up" style="animation-delay: 0.4s;">
        <a
          href={ctaLink}
          class="inline-flex items-center px-8 py-4 text-lg font-semibold text-blue-900 bg-white rounded-lg shadow-lg hover:bg-blue-50 hover:shadow-xl transform hover:-translate-y-1 transition-all duration-200"
        >
          {ctaText}
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        
        {secondaryCtaText && secondaryCtaLink && (
          <a
            href={secondaryCtaLink}
            class="inline-flex items-center px-8 py-4 text-lg font-semibold text-white border-2 border-white rounded-lg hover:bg-white hover:text-blue-900 transform hover:-translate-y-1 transition-all duration-200"
          >
            {secondaryCtaText}
          </a>
        )}
      </div>
      
      <!-- Trust Indicators -->
      <div class="mt-12 flex flex-wrap justify-center gap-8 text-blue-100 animate-fade-in-up" style="animation-delay: 0.6s;">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span>100% kostenlos</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span>Unverbindlich</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span>In 2 Minuten</span>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Wave SVG Bottom -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
      <path d="M0 120L60 105C120 90 240 60 360 45C480 30 600 30 720 37.5C840 45 960 60 1080 67.5C1200 75 1320 75 1380 75L1440 75V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
    </svg>
  </div>
</section>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in-up {
    animation: fade-in-up 0.8s ease-out forwards;
  }
  
  .hero-section {
    min-height: 600px;
  }
  
  @media (min-width: 768px) {
    .hero-section {
      min-height: 700px;
    }
  }
</style>
