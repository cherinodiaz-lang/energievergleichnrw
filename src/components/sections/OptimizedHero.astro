---
import { Image } from 'astro:assets';

interface Props {
  city: string;
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaUrl?: string;
  showImage?: boolean;
}

const {
  city,
  title,
  subtitle,
  ctaText = 'Jetzt vergleichen',
  ctaUrl = '#vergleich',
  showImage = true
} = Astro.props;

const cityName = city.charAt(0).toUpperCase() + city.slice(1);
---

<section class="hero-section" aria-label="Hauptbereich">
  <div class="hero-container">
    <!-- Content - NO MOTION for instant LCP -->
    <div class="hero-content">
      <!-- Breadcrumb Schema wird hier eingefügt -->
      
      <h1 class="hero-title">
        {title}
      </h1>
      
      <p class="hero-subtitle">
        {subtitle}
      </p>
      
      <!-- Benefits List -->
      <ul class="benefits-list" aria-label="Vorteile">
        <li>
          <svg class="benefit-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span>100% kostenlos & unabhängig</span>
        </li>
        <li>
          <svg class="benefit-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span>Bis zu 800€/Jahr sparen</span>
        </li>
        <li>
          <svg class="benefit-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span>In nur 2 Minuten fertig</span>
        </li>
      </ul>
      
      <!-- CTA Button -->
      <div class="hero-cta">
        <a href={ctaUrl} class="cta-button cta-primary">
          {ctaText}
          <svg class="cta-arrow" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
        
        <p class="trust-badge">
          <svg class="trust-icon" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          TÜV-zertifiziert & sicher
        </p>
      </div>
    </div>
    
    {showImage && (
      <div class="hero-image">
        <!-- Priority image for LCP optimization -->
        <img
          src="/images/hero-stromvergleich.svg"
          alt={`Stromvergleich in ${cityName} - Illustration`}
          width="600"
          height="500"
          loading="eager"
          decoding="sync"
          fetchpriority="high"
        />
      </div>
    )}
  </div>
</section>

<style>
  .hero-section {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 4rem 1rem;
  }
  
  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  
  @media (min-width: 768px) {
    .hero-container {
      grid-template-columns: 1fr 1fr;
    }
  }
  
  .hero-content {
    /* NO TRANSFORM/MOTION for instant paint */
  }
  
  .hero-title {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  
  @media (min-width: 768px) {
    .hero-title {
      font-size: 3.5rem;
    }
  }
  
  .hero-subtitle {
    font-size: 1.25rem;
    line-height: 1.6;
    opacity: 0.95;
    margin-bottom: 2rem;
  }
  
  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
  }
  
  .benefits-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 1.125rem;
  }
  
  .benefit-icon {
    width: 1.5rem;
    height: 1.5rem;
    color: #10b981;
    flex-shrink: 0;
  }
  
  .hero-cta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  
  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    font-size: 1.125rem;
    font-weight: 600;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  
  .cta-primary {
    background: white;
    color: #667eea;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }
  
  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
  }
  
  .cta-arrow {
    width: 1.25rem;
    height: 1.25rem;
  }
  
  .trust-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    opacity: 0.9;
  }
  
  .trust-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: #10b981;
  }
  
  .hero-image {
    /* Priority image - no lazy loading! */
  }
  
  .hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>