---
// Cookie Banner - DSGVO-konform (März 2026)
// Implementierung: In Layout einbinden
---

<div class="cookie-banner cookie-banner--hidden" id="cookieBanner" role="dialog" aria-labelledby="cookie-heading" aria-describedby="cookie-description">
  <div class="cookie-banner__content">
    <h2 class="cookie-banner__heading" id="cookie-heading">Cookie-Einstellungen</h2>
    
    <p class="cookie-banner__text" id="cookie-description">
      Wir verwenden Cookies und ähnliche Technologien, um Ihnen die beste Nutzererfahrung zu bieten und unsere Website zu verbessern. 
      Einige Cookies sind technisch notwendig, andere helfen uns, Inhalte zu personalisieren und unsere Dienstleistungen zu optimieren. 
      Sie können Ihre Einstellungen jederzeit ändern.
    </p>
    
    <div class="cookie-banner__buttons">
      <button class="cookie-banner__btn" id="cookieAcceptAll" aria-label="Alle Cookies akzeptieren">
        Alle akzeptieren
      </button>
      
      <button class="cookie-banner__btn" id="cookieRejectAll" aria-label="Alle nicht-notwendigen Cookies ablehnen">
        Alle ablehnen
      </button>
      
      <button class="cookie-banner__btn cookie-banner__btn--settings" id="cookieSettings" aria-label="Cookie-Einstellungen anpassen">
        Einstellungen
      </button>
    </div>
  </div>
</div>

<button class="cookie-settings-icon" id="cookieSettingsIcon" aria-label="Cookie-Einstellungen öffnen" style="display: none;">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"/>
    <path d="M8.5 8.5v.01"/>
    <path d="M16 15.5v.01"/>
    <path d="M12 12v.01"/>
    <path d="M11 17v.01"/>
    <path d="M7 14v.01"/>
  </svg>
  Cookie-Einstellungen
</button>

<script>
(function() {
  const banner = document.getElementById('cookieBanner');
  const icon = document.getElementById('cookieSettingsIcon');
  const acceptBtn = document.getElementById('cookieAcceptAll');
  const rejectBtn = document.getElementById('cookieRejectAll');
  const settingsBtn = document.getElementById('cookieSettings');
  
  function setCookie(name, value, days) {
    const date = new Date();
    date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
    document.cookie = name + '=' + value + ';expires=' + date.toUTCString() + ';path=/;SameSite=Lax';
  }
  
  function getCookie(name) {
    const value = '; ' + document.cookie;
    const parts = value.split('; ' + name + '=');
    if (parts.length === 2) return parts.pop().split(';').shift();
    return null;
  }
  
  const consent = getCookie('cookie_consent');
  if (!consent) {
    banner.classList.remove('cookie-banner--hidden');
  } else {
    icon.style.display = 'flex';
  }
  
  acceptBtn.addEventListener('click', function() {
    setCookie('cookie_consent', 'all', 365);
    banner.classList.add('cookie-banner--hidden');
    icon.style.display = 'flex';
  });
  
  rejectBtn.addEventListener('click', function() {
    setCookie('cookie_consent', 'necessary', 365);
    banner.classList.add('cookie-banner--hidden');
    icon.style.display = 'flex';
  });
  
  settingsBtn.addEventListener('click', function() {
    alert('Cookie-Einstellungen (erweiterte Modal-Implementierung folgt)');
  });
  
  icon.addEventListener('click', function() {
    banner.classList.remove('cookie-banner--hidden');
    icon.style.display = 'none';
  });
})();
</script>

<style>
  @import '../styles/cookie-banner.css';
</style>