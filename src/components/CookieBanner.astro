---
// Cookie Banner Component - DSGVO-konform
// Rechtliche Grundlage: Art. 7 DSGVO
---

<div class="cookie-banner cookie-banner--hidden" id="cookieBanner">
  <div class="cookie-banner__content">
    <h2 class="cookie-banner__heading">🍪 Cookies & Datenschutz</h2>
    <p class="cookie-banner__text">
      Wir verwenden Cookies, um Ihnen die bestmögliche Nutzererfahrung zu bieten. 
      Einige Cookies sind technisch notwendig, andere helfen uns, unsere Website zu verbessern.
      <a href="/datenschutz" style="color: #1d4ed8; text-decoration: underline;">Mehr erfahren</a>
    </p>
    <div class="cookie-banner__buttons">
      <button class="cookie-banner__btn cookie-banner__btn--outline" id="cookieAccept">Alle akzeptieren</button>
      <button class="cookie-banner__btn cookie-banner__btn--outline" id="cookieReject">Nur notwendige</button>
      <button class="cookie-banner__btn cookie-banner__btn--link" id="cookieSettings">Einstellungen</button>
    </div>
  </div>
</div>

<!-- Permanenter Cookie-Settings Button -->
<button class="cookie-settings-icon" id="cookieSettingsIcon" style="display: none;">
  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
  </svg>
  Cookie-Einstellungen
</button>

<script>
  // Cookie Banner Logic - DSGVO-konform
  document.addEventListener('DOMContentLoaded', () => {
    const banner = document.getElementById('cookieBanner');
    const acceptBtn = document.getElementById('cookieAccept');
    const rejectBtn = document.getElementById('cookieReject');
    const settingsBtn = document.getElementById('cookieSettings');
    const settingsIcon = document.getElementById('cookieSettingsIcon');

    // Prüfe ob Consent bereits gesetzt
    const consent = localStorage.getItem('cookie-consent');
    if (!consent) {
      banner.classList.remove('cookie-banner--hidden');
    } else {
      settingsIcon.style.display = 'flex';
    }

    // Alle Cookies akzeptieren
    acceptBtn.addEventListener('click', () => {
      localStorage.setItem('cookie-consent', 'all');
      banner.classList.add('cookie-banner--hidden');
      settingsIcon.style.display = 'flex';
      // Analytics aktivieren (später)
      if (typeof window !== 'undefined' && window.location.search.includes('debug=1')) {
        console.log('✅ Alle Cookies akzeptiert');
      }
    });

    // Nur notwendige Cookies
    rejectBtn.addEventListener('click', () => {
      localStorage.setItem('cookie-consent', 'necessary');
      banner.classList.add('cookie-banner--hidden');
      settingsIcon.style.display = 'flex';
      if (typeof window !== 'undefined' && window.location.search.includes('debug=1')) {
        console.log('✅ Nur notwendige Cookies');
      }
    });

    // Settings öffnen
    settingsBtn.addEventListener('click', () => {
      window.location.href = '/datenschutz#cookies';
    });

    // Settings Icon
    settingsIcon.addEventListener('click', () => {
      banner.classList.remove('cookie-banner--hidden');
      settingsIcon.style.display = 'none';
    });
  });
</script>

<style>
  @import url('/src/assets/css/cookie-banner.css');
</style>
