---
interface Props {
  city: string;
  address?: {
    street?: string;
    postalCode: string;
    city: string;
  };
}

const { city, address } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": `Energievergleich NRW - ${city}`,
  "description": `Vergleichen Sie Strom- und Gasanbieter in ${city}. Finden Sie den günstigsten Tarif und sparen Sie bis zu 500€ pro Jahr.`,
  "url": `https://energievergleich-nrw.de/${city.toLowerCase()}`,
  "telephone": "+49-221-12345678",
  "priceRange": "€€",
  "address": address ? {
    "@type": "PostalAddress",
    "streetAddress": address.street || "",
    "addressLocality": address.city,
    "postalCode": address.postalCode,
    "addressRegion": "NRW",
    "addressCountry": "DE"
  } : undefined,
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "51.0",
    "longitude": "7.0"
  },
  "areaServed": {
    "@type": "City",
    "name": city,
    "containedIn": {
      "@type": "State",
      "name": "Nordrhein-Westfalen"
    }
  },
  "sameAs": [
    "https://facebook.com/energievergleichnrw",
    "https://twitter.com/energievergleichnrw"
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "1250",
    "bestRating": "5",
    "worstRating": "1"
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />