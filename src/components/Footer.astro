---
import globalContent from '@content/de/global.json';

const { footer } = globalContent;
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-section">
        <h3 class="footer-title">energievergleich.shop</h3>
        <p class="footer-text">Tarife vergleichen. Klar entscheiden. Einfach wechseln.</p>
      </div>
      <div class="footer-section">
        <h4 class="footer-heading">Navigation</h4>
        <ul class="footer-links">
          {footer.links.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="footer-legal">
        © {currentYear} energievergleich.shop • 
        <a href="/impressum" class="footer-link">Impressum</a> • 
        <a href="/datenschutz" class="footer-link">Datenschutz</a>
      </p>
      <p class="footer-disclaimer">{footer.disclaimerShort}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: var(--s-7) 0 var(--s-5);
    background: var(--bg-soft);
    margin-top: var(--s-9);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--s-6);
    margin-bottom: var(--s-6);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--s-5);
    }
  }

  .footer-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 var(--s-2);
    color: var(--text-900);
  }

  .footer-heading {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 var(--s-3);
    color: var(--text-900);
  }

  .footer-text {
    color: var(--text-700);
    margin: 0;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }

  .footer-links a {
    color: var(--text-700);
    text-decoration: none;
    font-size: 0.9375rem;
  }

  .footer-links a:hover {
    color: var(--primary);
  }

  .footer-bottom {
    padding-top: var(--s-5);
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }

  .footer-legal,
  .footer-disclaimer {
    font-size: 0.875rem;
    color: var(--text-600);
    margin: 0;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .footer-link {
    color: var(--text-600);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--primary);
    text-decoration: underline;
  }
</style>
