---
interface Props {
  title: string;
  description: string;
  highlights: string[];
}

const { title, description, highlights } = Astro.props;
---

<section class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:px-8">
  <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">
      Energievergleich NRW
    </p>
    <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">
      {title}
    </h1>
    <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">
      {description}
    </p>
    <ul class="mt-8 grid gap-3 sm:grid-cols-3">
      {highlights.map((highlight) => (
        <li class="rounded-2xl bg-slate-50 px-4 py-3 text-sm font-medium text-slate-700">
          {highlight}
        </li>
      ))}
    </ul>
  </div>
</section>
