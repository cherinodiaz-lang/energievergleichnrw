---
import globalContent from '@content/de/global.json';

const { brand, nav, cta } = globalContent;
---

<header class="site-header">
  <div class="container">
    <nav class="nav" role="navigation" aria-label="Hauptnavigation">
      <a href="/" class="brand" aria-label="Zur Startseite">
        {brand.name}
      </a>
      <div class="nav-links">
        {nav.map((item) => (
          <a href={item.href} class="nav-link">{item.label}</a>
        ))}
      </div>
      <a href="/#vergleich" class="btn btn-primary btn-sm">{cta.primary}</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    padding: var(--s-3) 0;
  }

  .brand {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--text-900);
    text-decoration: none;
  }

  .brand:hover {
    color: var(--primary);
  }

  .nav-links {
    display: flex;
    gap: var(--s-4);
    flex-wrap: wrap;
  }

  .nav-link {
    color: var(--text-700);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--text-900);
  }

  .btn-sm {
    padding: 8px 16px;
    font-size: 0.875rem;
    min-height: 36px;
  }

  @media (max-width: 900px) {
    .nav {
      flex-direction: column;
      align-items: stretch;
      gap: var(--s-3);
    }

    .nav-links {
      flex-direction: column;
      gap: var(--s-2);
    }

    .btn-sm {
      text-align: center;
    }
  }
</style>
