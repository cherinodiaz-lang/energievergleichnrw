---
import HydratedMarketingPage from "@/components/HydratedMarketingPage";
import LighthousePageFallback from "@/components/LighthousePageFallback.astro";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
import { getPageSEO } from "@/lib/seo-config";

const seo = getPageSEO("home");
---

<SeoPageLayout
  title={seo.title}
  description={seo.description}
  canonicalPath="/"
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>
  <HydratedMarketingPage path={Astro.url.pathname} page="home" client:only="react">
    <LighthousePageFallback
      slot="fallback"
      title="Energievergleich NRW 2026"
      description="Erhalten Sie eine unverbindliche Strom- und Gas-Tariforientierung in NRW mit transparenten Beispielwerten fuer Privat- und Gewerbekunden."
      highlights={["Unverbindliche Orientierung", "Beispielwerte fuer NRW", "Anfrage moeglich"]}
    />
  </HydratedMarketingPage>
</SeoPageLayout>
