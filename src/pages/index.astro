---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import Stats from '@/components/sections/Stats.astro';
import Features from '@/components/sections/Features.astro';
import CtaSection from '@/components/sections/CtaSection.astro';
import { ComparisonForm } from '@/components/forms/ComparisonForm';

const features = [
  {
    icon: '💰',
    title: 'Bis zu 800€ sparen',
    description: 'Vergleichen Sie Hunderte von Tarifen und finden Sie garantiert günstigere Angebote als Ihren aktuellen Vertrag.'
  },
  {
    icon: '⚡',
    title: 'In 2 Minuten fertig',
    description: 'Schneller Vergleich ohne Papierkram. Geben Sie einfach Ihre PLZ und Ihren Verbrauch ein - fertig!'
  },
  {
    icon: '🔒',
    title: '100% kostenlos',
    description: 'Unser Service ist komplett kostenlos und unverbindlich. Keine versteckten Kosten, keine Abofallen.'
  },
  {
    icon: '🎯',
    title: 'Alle Anbieter',
    description: 'Wir vergleichen über 1.000 Tarife von mehr als 100 Anbietern in ganz NRW.'
  },
  {
    icon: '✅',
    title: 'Geprüft & sicher',
    description: 'Alle Tarife sind von uns geprüft. Faire Konditionen und transparente Preise garantiert.'
  },
  {
    icon: '📞',
    title: 'Persönliche Beratung',
    description: 'Bei Fragen helfen Ihnen unsere Experten gerne weiter - kostenlos und unverbindlich.'
  }
];

const stats = [
  { value: '1000', label: 'Tarife', suffix: '+' },
  { value: '100', label: 'Anbieter', suffix: '+' },
  { value: '800', label: 'Ersparnis', suffix: '€' },
  { value: '50000', label: 'Zufriedene Kunden', suffix: '+' }
];
---

<BaseLayout
  title="Energievergleich NRW - Strom & Gas vergleichen und bis zu 800€ sparen"
  description="Vergleichen Sie Strom- und Gasanbieter in NRW. Finden Sie in 2 Minuten den günstigsten Tarif und sparen Sie bis zu 800€ jährlich. 100% kostenlos & unverbindlich."
  canonical="https://energievergleichnrw.de/"
>
  <!-- Hero Section -->
  <Hero
    title="Energiekosten senken in NRW"
    subtitle="Vergleichen Sie Strom- und Gasanbieter und sparen Sie bis zu 800€ pro Jahr. Kostenlos, schnell und unverbindlich."
    ctaText="Jetzt kostenlos vergleichen"
    ctaLink="#vergleich"
    secondaryCtaText="Mehr erfahren"
    secondaryCtaLink="#features"
  />
  
  <!-- Stats Section -->
  <Stats
    title="Vertrauen Sie auf unsere Erfahrung"
    stats={stats}
  />
  
  <!-- Features Section -->
  <Features
    title="Warum Energievergleich NRW?"
    subtitle="Ihre Vorteile auf einen Blick"
    features={features}
  />
  
  <!-- Comparison Form Section -->
  <section id="vergleich" class="py-16 sm:py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
          Jetzt Tarife vergleichen
        </h2>
        <p class="text-xl text-gray-600">
          In nur 2 Minuten zu Ihrem neuen günstigen Tarif
        </p>
      </div>
      
      <ComparisonForm client:load />
    </div>
  </section>
  
  <!-- CTA Section -->
  <CtaSection
    title="Bereit zum Wechseln?"
    description="Starten Sie jetzt Ihren kostenlosen Vergleich und sichern Sie sich die besten Tarife in Nordrhein-Westfalen."
    ctaText="Jetzt Geld sparen"
    ctaLink="#vergleich"
    variant="primary"
  />
  
  <!-- Trust Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">
          Häufig gestellte Fragen
        </h2>
        
        <div class="space-y-6">
          <details class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
            <summary class="font-semibold text-lg text-gray-900 cursor-pointer">
              Ist der Vergleich wirklich kostenlos?
            </summary>
            <p class="mt-4 text-gray-600">
              Ja, unser Vergleichsservice ist 100% kostenlos und unverbindlich. Sie zahlen nichts für den Vergleich oder unsere Beratung.
            </p>
          </details>
          
          <details class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
            <summary class="font-semibold text-lg text-gray-900 cursor-pointer">
              Wie viel kann ich wirklich sparen?
            </summary>
            <p class="mt-4 text-gray-600">
              Im Durchschnitt sparen unsere Kunden zwischen 300-800€ pro Jahr durch den Wechsel zu einem günstigeren Anbieter. Die genaue Ersparnis hängt von Ihrem Verbrauch und aktuellen Tarif ab.
            </p>
          </details>
          
          <details class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
            <summary class="font-semibold text-lg text-gray-900 cursor-pointer">
              Wie lange dauert ein Anbieterwechsel?
            </summary>
            <p class="mt-4 text-gray-600">
              Der Wechsel dauert in der Regel 2-6 Wochen. Ihr neuer Anbieter übernimmt alle Formalitäten, Sie müssen nichts weiter tun. Ihre Versorgung ist während des Wechsels natürlich durchgehend gesichert.
            </p>
          </details>
          
          <details class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
            <summary class="font-semibold text-lg text-gray-900 cursor-pointer">
              Gibt es versteckte Kosten?
            </summary>
            <p class="mt-4 text-gray-600">
              Nein! Alle angezeigten Preise sind transparent und beinhalten alle Kosten. Wir zeigen nur geprüfte Tarife ohne versteckte Kosten oder unnötige Zusatzoptionen.
            </p>
          </details>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  details summary {
    list-style: none;
  }
  
  details summary::-webkit-details-marker {
    display: none;
  }
  
  details summary::after {
    content: '+';
    float: right;
    font-size: 1.5rem;
    font-weight: bold;
    color: #2563eb;
  }
  
  details[open] summary::after {
    content: '−';
  }
</style>
