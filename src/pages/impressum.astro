---
import HydratedRoutePage from "@/components/HydratedRoutePage";
import ImpressumPage from "@/components/pages/ImpressumPage";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
import { getPageSEO } from "@/lib/seo-config";

const seo = getPageSEO("impressum");
---

<SeoPageLayout
  title={seo.title}
  description={seo.description}
  canonicalPath="/impressum"
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>
  <HydratedRoutePage client:load path={Astro.url.pathname} Page={ImpressumPage} />
</SeoPageLayout>
