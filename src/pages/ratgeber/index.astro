---
import AstroRouterProvider from "@/components/AstroRouterProvider";
import RatgeberPage from "@/components/pages/RatgeberPage";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
import { getPageSEO } from "@/lib/seo-config";

const seo = getPageSEO("ratgeber");
---

<SeoPageLayout
  title={seo.title}
  description={seo.description}
  canonicalPath="/ratgeber"
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>
  <AstroRouterProvider path={Astro.url.pathname} client:idle>
    <RatgeberPage />
  </AstroRouterProvider>
</SeoPageLayout>
