---
import HydratedRoutePage from "@/components/HydratedRoutePage";
import MethodologyPage from "@/components/pages/MethodologyPage";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
import { getPageSEO } from "@/lib/seo-config";

const seo = getPageSEO("methodik");
---

<SeoPageLayout
  title={seo.title}
  description={seo.description}
  canonicalPath="/methodik"
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>
  <HydratedRoutePage path={Astro.url.pathname} Page={MethodologyPage} client:idle />
</SeoPageLayout>
