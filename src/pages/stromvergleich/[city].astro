---
import HydratedRoutePage from "@/components/HydratedRoutePage";
import CityComparisonPage from "@/components/pages/CityComparisonPage";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
import {
  CITIES,
  calcJahresersparnis,
  getCityBySlug,
  getStromCityFaqs,
  getStromCityPath,
} from "@/lib/cities";
import { SEO_CONFIG } from "@/lib/seo-config";

export function getStaticPaths() {
  return CITIES.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }));
}

const city = Astro.props.city ?? getCityBySlug(Astro.params.city ?? "");

if (!city) {
  throw new Error(`Unknown city slug: ${Astro.params.city}`);
}

const pagePath = getStromCityPath(city.slug);
const faqItems = getStromCityFaqs(city);
const savings = calcJahresersparnis(
  city.stromGrundversorgungCt,
  city.stromVergleichCt,
  city.stromSampleConsumptionKwh,
);
const title = `Stromvergleich ${city.name} 2026 | Stromtarife für ${city.name} vergleichen`;
const description = `Stromvergleich für ${city.name}: Live-Tarife für ${city.postalCodeHint}, lokale Orientierung zu Grundversorgung, Preisgarantie und Stromkosten. Jetzt Stromtarife für ${city.name} prüfen.`;
const keywords = `Stromvergleich ${city.name}, Stromtarife ${city.name}, Stromanbieter ${city.name}, Strompreis ${city.name}, Stromvergleich NRW`;

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Startseite",
        item: `${SEO_CONFIG.siteUrl}/`,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Stromvergleich NRW",
        item: `${SEO_CONFIG.siteUrl}/stromvergleich-nrw`,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: `Stromvergleich ${city.name}`,
        item: `${SEO_CONFIG.siteUrl}${pagePath}`,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((faq) => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.answer,
      },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: `Stromvergleich ${city.name}`,
    serviceType: "Stromvergleich",
    url: `${SEO_CONFIG.siteUrl}${pagePath}`,
    description,
    provider: {
      "@type": "Organization",
      name: SEO_CONFIG.siteName,
      url: SEO_CONFIG.siteUrl,
    },
    areaServed: {
      "@type": "City",
      name: city.name,
      containedInPlace: {
        "@type": "State",
        name: "Nordrhein-Westfalen",
      },
    },
    offers: {
      "@type": "Offer",
      description: `Beispielhafte Orientierung: rund ${savings.toLocaleString("de-DE")} Euro Sparpotenzial pro Jahr bei ${city.stromSampleConsumptionKwh.toLocaleString("de-DE")} kWh.`,
    },
  },
];
---

<SeoPageLayout
  title={title}
  description={description}
  canonicalPath={pagePath}
  keywords={keywords}
  ogTitle={title}
  ogDescription={description}
  schemas={schemas}
>
  <HydratedRoutePage
    path={Astro.url.pathname}
    Page={CityComparisonPage}
    pageProps={{ city, comparisonType: "strom" }}
    client:load
  />
</SeoPageLayout>
