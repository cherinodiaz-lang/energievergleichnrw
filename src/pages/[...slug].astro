---
import { SEO } from '@wix/seo/components';
import { loadSEOTagsServiceConfig } from '@wix/seo/services';
import { Head } from "@/components/Head";
import AppRouter from "@/components/Router";
import "@wix/wix-vibe-plugins/plugins-vars.css";
import "@wix/wix-vibe-plugins/plugins-theme.css";
import "@/styles/global.css";

const CANONICAL_ORIGIN = 'https://www.energievergleich.shop';

const pathname = new URL(Astro.request.url).pathname;
const slug = pathname.replace(/^\/+/, '');

const capitalize = (word) => {
  const w = String(word || '').trim();
  if (!w) return '';
  if (w.toLowerCase() === 'nrw') return 'NRW';
  return w.charAt(0).toUpperCase() + w.slice(1);
};

const titleCaseFromSlug = (value) =>
  String(value || '')
    .split('-')
    .filter(Boolean)
    .map(capitalize)
    .join(' ');

const pageNameFromPath = (slugValue) => {
  if (!slugValue) return 'Home';

  const parts = String(slugValue).split('-').filter(Boolean);
  const prefix = (parts[0] || '').toLowerCase();

  const prefixMap = {
    stromvergleich: 'Stromvergleich',
    gasvergleich: 'Gasvergleich',
    photovoltaik: 'Photovoltaik',
  };

  // Common pattern: stromvergleich-essen, gasvergleich-bochum, photovoltaik-duesseldorf
  if (prefixMap[prefix] && parts.length >= 2) {
    const rest = parts.slice(1).join(' ');
    return `${prefixMap[prefix]} ${rest.split(' ').map(capitalize).join(' ')}`;
  }

  // Fallback: Title Case the whole slug
  return titleCaseFromSlug(slugValue);
};

const pageName = pageNameFromPath(slug);
const canonicalUrl = `${CANONICAL_ORIGIN}${pathname}`;

const seoTagsServiceConfig = await loadSEOTagsServiceConfig({
  // Force canonical origin, even if the request is served via preview/alternate domain
  pageUrl: canonicalUrl,
  itemData: {
    pageName,
  },
});

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Startseite",
      "item": `${CANONICAL_ORIGIN}/`,
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": pageName,
      "item": canonicalUrl,
    },
  ],
};
---

<html lang="de" class="w-full h-full">
  <head>
    <Head />
    <SEO.Tags seoTagsServiceConfig={seoTagsServiceConfig} slot="seo-tags" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </head>
  <body class="w-full h-full">
    <div id="root" class="w-full h-full">
      <AppRouter client:only="react" />
    </div>
  </body>
</html>
