---
import AstroRouterProvider from "@/components/AstroRouterProvider";
import DatenschutzPage from "@/components/pages/DatenschutzPage";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
import { getPageSEO } from "@/lib/seo-config";

const seo = getPageSEO("datenschutz");
---

<SeoPageLayout
  title={seo.title}
  description={seo.description}
  canonicalPath="/datenschutz"
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>
  <AstroRouterProvider path={Astro.url.pathname} Page={DatenschutzPage} />
</SeoPageLayout>
