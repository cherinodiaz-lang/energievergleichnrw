---
/**
 * 404 Error Page
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 - Seite nicht gefunden | EnergieVergleich NRW"
  description="Die angeforderte Seite konnte nicht gefunden werden."
  noindex={true}
>
  <div class="error-container">
    <div class="error-content">
      <h1 class="error-code">404</h1>
      <h2 class="error-title">Seite nicht gefunden</h2>
      <p class="error-text">
        Die von Ihnen gesuchte Seite existiert leider nicht oder wurde verschoben.
      </p>
      
      <div class="error-actions">
        <a href="/" class="btn btn-primary">Zur Startseite</a>
        <a href="/stromvergleich-nrw" class="btn btn-secondary">Zum Stromvergleich</a>
      </div>
      
      <div class="popular-pages">
        <h3>Beliebte Seiten:</h3>
        <ul>
          <li><a href="/stromvergleich-nrw">Stromvergleich NRW</a></li>
          <li><a href="/gasvergleich-nrw">Gasvergleich NRW</a></li>
          <li><a href="/#faq">Häufige Fragen</a></li>
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .error-container {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--s-5);
  }
  
  .error-content {
    text-align: center;
    max-width: 600px;
  }
  
  .error-code {
    font-size: 8rem;
    font-weight: 900;
    color: var(--primary);
    line-height: 1;
    margin-bottom: var(--s-3);
    opacity: 0.2;
  }
  
  .error-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: var(--s-4);
  }
  
  .error-text {
    font-size: 1.125rem;
    color: var(--text-700);
    margin-bottom: var(--s-5);
  }
  
  .error-actions {
    display: flex;
    gap: var(--s-3);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--s-7);
  }
  
  .popular-pages {
    text-align: left;
    padding: var(--s-5);
    background: var(--bg-soft);
    border-radius: var(--r-2);
  }
  
  .popular-pages h3 {
    font-size: 1.125rem;
    margin-bottom: var(--s-3);
  }
  
  .popular-pages ul {
    list-style: none;
    padding: 0;
  }
  
  .popular-pages li {
    margin-bottom: var(--s-3);
  }
  
  .popular-pages a {
    color: var(--primary);
    text-decoration: none;
    font-weight: 500;
  }
  
  .popular-pages a:hover {
    text-decoration: underline;
  }
</style>
