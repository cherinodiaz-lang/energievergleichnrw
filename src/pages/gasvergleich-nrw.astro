---
import BaseLayout from '@/layouts/BaseLayout.astro';
import gasContent from '@content/de/pages/gasvergleich-nrw.json';

const { meta, badge, h1, subline, primaryCta, jsonLd, faqItems } = gasContent;
---

<BaseLayout title={meta.title} description={meta.description} jsonLd={jsonLd} faqItems={faqItems}>
  <main>
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-content">
            <span class="badge">{badge}</span>
            <h1 class="h1">{h1}</h1>
            <p class="lead">{subline}</p>
            <a href="#vergleich" class="btn btn-primary btn-lg">{primaryCta}</a>
          </div>
          <div class="hero-form" id="vergleich">
            <!-- Form will be React component later -->
            <div class="card">
              <p class="card-title">Gastarif prüfen</p>
              <p class="card-text">PLZ + Heizverhalten: schnell und verständlich.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Value Props Section -->
    <section class="section">
      <div class="container">
        <h2 class="h2 text-center">Worauf es beim Gastarif wirklich ankommt</h2>
        <div class="grid-3">
          <div class="card">
            <p class="card-title">Preisbestandteile</p>
            <p class="card-text">
              Arbeitspreis, Grundpreis und regionale Bestandteile verständlich erklärt.
            </p>
          </div>
          <div class="card">
            <p class="card-title">Laufzeit & Kündigung</p>
            <p class="card-text">
              Kurz und flexibel ist oft besser – wir zeigen dir die Stellschrauben.
            </p>
          </div>
          <div class="card">
            <p class="card-title">Bonus & Preisgarantie</p>
            <p class="card-text">
              Wir erklären Vor- und Nachteile, damit du sauber vergleichen kannst.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="section bg-soft">
      <div class="container">
        <h2 class="h2 text-center">FAQ Gasvergleich NRW</h2>
        <div class="faq-list">
          {
            faqItems.map((item) => (
              <details class="faq-item">
                <summary class="faq-question">{item.q}</summary>
                <p class="faq-answer">{item.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="section">
      <div class="container text-center">
        <h2 class="h2">Jetzt Gastarif prüfen</h2>
        <p class="lead">PLZ eingeben und in wenigen Schritten zur passenden Option.</p>
        <a href="#vergleich" class="btn btn-primary btn-lg">{primaryCta}</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero-section {
    padding: var(--s-8) 0;
    background: linear-gradient(180deg, #f8fafc, #ffffff);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--s-7);
    align-items: start;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--s-5);
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    border: 1px solid var(--border);
    background: white;
    border-radius: 999px;
    font-size: 0.875rem;
    color: var(--text-700);
    width: fit-content;
  }

  .lead {
    font-size: 1.125rem;
    color: var(--text-700);
  }

  .section {
    padding: var(--s-8) 0;
  }

  .bg-soft {
    background: var(--bg-soft);
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-5);
    margin-top: var(--s-5);
  }

  @media (max-width: 900px) {
    .grid-3 {
      grid-template-columns: 1fr;
    }
  }

  .text-center {
    text-align: center;
  }

  .faq-list {
    max-width: 800px;
    margin: var(--s-5) auto 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }

  .faq-item {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--r-2);
    padding: var(--s-4);
  }

  .faq-question {
    font-weight: 700;
    cursor: pointer;
    list-style: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-answer {
    margin-top: var(--s-3);
    color: var(--text-700);
  }

  .btn-lg {
    padding: 16px 32px;
    font-size: 1.125rem;
  }
</style>
