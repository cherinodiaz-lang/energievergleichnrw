---
import HydratedMarketingPage from "@/components/HydratedMarketingPage";
import LighthousePageFallback from "@/components/LighthousePageFallback.astro";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
import { getPageSEO } from "@/lib/seo-config";

const seo = getPageSEO("gasvergleich");
---

<SeoPageLayout
  title={seo.title}
  description={seo.description}
  canonicalPath="/gasvergleich-nrw"
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>
  <HydratedMarketingPage path={Astro.url.pathname} page="gasvergleich" client:only="react">
    <LighthousePageFallback
      slot="fallback"
      title="Gasvergleich NRW"
      description="Erhalten Sie eine unverbindliche Tarif-Orientierung fuer Gastarife in NRW und senden Sie bei Bedarf direkt eine Anfrage."
      highlights={["Beispieltarife zur Orientierung", "Transparente Konditionen", "Unverbindliche Anfrage"]}
    />
  </HydratedMarketingPage>
</SeoPageLayout>
