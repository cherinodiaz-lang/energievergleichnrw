---
import AstroRouterProvider from "@/components/AstroRouterProvider";
import FaqPage from "@/components/pages/FaqPage";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
---

<SeoPageLayout
  title="FAQ | Energievergleich"
  description="Häufige Fragen zu Stromvergleich, Gasvergleich, Photovoltaik und Anbieterwechsel."
  canonicalPath="/faq"
  keywords="FAQ, Stromvergleich, Gasvergleich, Photovoltaik, Anbieterwechsel"
  ogTitle="FAQ | Energievergleich"
  ogDescription="Häufige Fragen zu Strom, Gas, Photovoltaik und Anbieterwechsel"
>
  <AstroRouterProvider client:load path={Astro.url.pathname} Page={FaqPage} />
</SeoPageLayout>
