---
import AstroRouterProvider from "@/components/AstroRouterProvider";
import KontaktPage from "@/components/pages/KontaktPage";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
import { getPageSEO } from "@/lib/seo-config";

const seo = getPageSEO("kontakt");
---

<SeoPageLayout
  title={seo.title}
  description={seo.description}
  canonicalPath="/kontakt"
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>
  <AstroRouterProvider path={Astro.url.pathname} Page={KontaktPage} />
</SeoPageLayout>
