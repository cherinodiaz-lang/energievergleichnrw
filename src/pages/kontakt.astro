---
import HydratedMarketingPage from "@/components/HydratedMarketingPage";
import LighthousePageFallback from "@/components/LighthousePageFallback.astro";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
import { getPageSEO } from "@/lib/seo-config";

const seo = getPageSEO("kontakt");
---

<SeoPageLayout
  title={seo.title}
  description={seo.description}
  canonicalPath="/kontakt"
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>
  <HydratedMarketingPage path={Astro.url.pathname} page="kontakt" client:only="react">
    <LighthousePageFallback
      slot="fallback"
      title="Kontakt"
      description="Kontaktieren Sie ENERGIEVERGLEICH NRW fuer Fragen zu Strom, Gas oder Photovoltaik in NRW."
      highlights={["E-Mail: support@energievergleich.nrw", "Region: NRW", "Unverbindliche Anfrage"]}
    />
  </HydratedMarketingPage>
</SeoPageLayout>
