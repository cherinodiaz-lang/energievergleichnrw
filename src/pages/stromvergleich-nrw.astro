---
import HydratedMarketingPage from "@/components/HydratedMarketingPage";
import LighthousePageFallback from "@/components/LighthousePageFallback.astro";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
import { getPageSEO } from "@/lib/seo-config";

const seo = getPageSEO("stromvergleich");
---

<SeoPageLayout
  title={seo.title}
  description={seo.description}
  canonicalPath="/stromvergleich-nrw"
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>
  <HydratedMarketingPage path={Astro.url.pathname} page="stromvergleich" client:only="react">
    <LighthousePageFallback
      slot="fallback"
      title="Stromvergleich NRW"
      description="Finden Sie guenstige Stromtarife fuer Ihren Haushalt in NRW, vergleichen Sie Leistungen transparent und sichern Sie sich einen schnellen Wechsel ohne Papierchaos."
      highlights={["Stromtarife transparent", "Sofort Preisvorteile sehen", "Unabhaengig und sicher wechseln"]}
    />
  </HydratedMarketingPage>
</SeoPageLayout>
