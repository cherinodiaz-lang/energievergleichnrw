---
import HydratedRoutePage from "@/components/HydratedRoutePage";
import StromvergleichNrwPage from "@/components/pages/StromvergleichNrwPage";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
import { getPageSEO } from "@/lib/seo-config";

const seo = getPageSEO("stromvergleich");
---

<SeoPageLayout
  title={seo.title}
  description={seo.description}
  canonicalPath="/stromvergleich-nrw"
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>
  <HydratedRoutePage path={Astro.url.pathname} Page={StromvergleichNrwPage} client:load />
</SeoPageLayout>
