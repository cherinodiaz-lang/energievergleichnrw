---
/**
 * Offline Fallback Page
 * Wird angezeigt wenn Service Worker keine Verbindung hat
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Offline - EnergieVergleich NRW"
  description="Sie sind offline. Bitte überprüfen Sie Ihre Internetverbindung."
  noindex={true}
>
  <div class="offline-container">
    <div class="offline-content">
      <svg
        class="offline-icon"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M18.364 5.636a9 9 0 010 12.728m0 0l-2.829-2.829m2.829 2.829L21 21M15.536 8.464a5 5 0 010 7.072m0 0l-2.829-2.829m-4.243 2.829a4.978 4.978 0 01-1.414-2.83m-1.414 5.658a9 9 0 01-2.167-9.238m7.824 2.167a1 1 0 111.414 1.414m-1.414-1.414L3 3m8.293 8.293l1.414 1.414"
        ></path>
      </svg>
      
      <h1 class="offline-title">Sie sind offline</h1>
      <p class="offline-text">
        Keine Internetverbindung verfügbar. Bitte überprüfen Sie Ihre Verbindung und versuchen Sie es erneut.
      </p>
      
      <button
        onclick="window.location.reload()"
        class="btn btn-primary"
      >
        Erneut versuchen
      </button>
      
      <div class="offline-info">
        <p>
          <strong>Tipp:</strong> Einige Inhalte können möglicherweise offline verfügbar sein.
          Versuchen Sie, zu bereits besuchten Seiten zurückzukehren.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .offline-container {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--s-5);
  }
  
  .offline-content {
    text-align: center;
    max-width: 500px;
  }
  
  .offline-icon {
    width: 120px;
    height: 120px;
    margin: 0 auto var(--s-5);
    color: var(--text-700);
    opacity: 0.5;
  }
  
  .offline-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: var(--s-3);
  }
  
  .offline-text {
    font-size: 1.125rem;
    color: var(--text-700);
    margin-bottom: var(--s-5);
    line-height: 1.6;
  }
  
  .offline-info {
    margin-top: var(--s-5);
    padding: var(--s-4);
    background: var(--bg-soft);
    border-radius: var(--r-2);
    border-left: 4px solid var(--primary);
  }
  
  .offline-info p {
    font-size: 0.9rem;
    color: var(--text-700);
    text-align: left;
    margin: 0;
  }
</style>
