---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="500 - Serverfehler | EnergieVergleich NRW"
  description="Ein unerwarteter Fehler ist aufgetreten."
  noindex={true}
>
  <section class="error-page">
    <div class="container">
      <div class="error-content">
        <h1 class="error-code">500</h1>
        <h2 class="error-title">Serverfehler</h2>
        <p class="error-text">
          Ein unerwarteter Fehler ist aufgetreten. Wir arbeiten bereits an einer Lösung.
        </p>
        <div class="error-actions">
          <a href="/" class="btn btn-primary">Zur Startseite</a>
          <button onclick="window.location.reload()" class="btn btn-secondary">
            Seite neu laden
          </button>
        </div>
        
        <div class="error-info">
          <p>Falls das Problem weiterhin besteht, kontaktieren Sie uns bitte:</p>
          <a href="mailto:support@energievergleichnrw.de" class="contact-link">
            support@energievergleichnrw.de
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .error-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--s-8) 0;
  }
  
  .error-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .error-code {
    font-size: clamp(4rem, 15vw, 10rem);
    font-weight: 900;
    color: #dc2626;
    line-height: 1;
    margin-bottom: var(--s-3);
  }
  
  .error-title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: var(--s-4);
  }
  
  .error-text {
    font-size: 1.125rem;
    color: var(--text-700);
    margin-bottom: var(--s-6);
  }
  
  .error-actions {
    display: flex;
    gap: var(--s-3);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--s-6);
  }
  
  .error-info {
    margin-top: var(--s-6);
    padding-top: var(--s-6);
    border-top: 1px solid var(--border);
  }
  
  .contact-link {
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
  }
  
  .contact-link:hover {
    text-decoration: underline;
  }
</style>
