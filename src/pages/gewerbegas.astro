---
import HydratedRoutePage from "@/components/HydratedRoutePage";
import GewerbegasPage from "@/components/pages/GewerbegasPage";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
import { getPageSEO } from "@/lib/seo-config";

const seo = getPageSEO("gewerbegas");
---

<SeoPageLayout
  title={seo.title}
  description={seo.description}
  canonicalPath="/gewerbegas"
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>
  <HydratedRoutePage path={Astro.url.pathname} Page={GewerbegasPage} client:load />
</SeoPageLayout>
