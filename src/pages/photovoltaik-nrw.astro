---
import AstroRouterProvider from "@/components/AstroRouterProvider";
import PhotovoltaikNrwPage from "@/components/pages/PhotovoltaikNrwPage";
import SeoPageLayout from "@/layouts/SeoPageLayout.astro";
import { getPageSEO } from "@/lib/seo-config";

const seo = getPageSEO("photovoltaik");
---

<SeoPageLayout
  title={seo.title}
  description={seo.description}
  canonicalPath="/photovoltaik-nrw"
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>
  <AstroRouterProvider path={Astro.url.pathname} Page={PhotovoltaikNrwPage} client:load />
</SeoPageLayout>
