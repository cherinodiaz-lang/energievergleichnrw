# Wix Integration
WIX_API_KEY=your_wix_api_key_here
WIX_SITE_ID=your_wix_site_id_here
WIX_ACCOUNT_ID=your_wix_account_id_here

# Wix Vibe (AI Website Builder)
WIX_VIBE_ENABLED=true
WIX_VIBE_API_KEY=your_vibe_api_key_here

# Public Environment Variables (Available in Browser)
PUBLIC_SITE_URL=https://energievergleichnrw.de
PUBLIC_SITE_NAME="Energievergleich NRW"

# Analytics
PUBLIC_GA_ID=G-XXXXXXXXXX
PUBLIC_GTM_ID=GTM-XXXXXXX

# API Keys (Server-side only)
API_SECRET_KEY=your_secret_key_here

# Database (if needed)
DATABASE_URL=your_database_url_here

# Email Service
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_password_here
