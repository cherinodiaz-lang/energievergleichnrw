# Environment Variables Template
# Kopiere diese Datei zu .env und fülle die Werte aus

# Site Configuration
PUBLIC_SITE_URL=https://energievergleichnrw.de
PUBLIC_SITE_NAME="EnergieVergleich NRW"

# Analytics
PUBLIC_GA_ID=G-XXXXXXXXXX
PUBLIC_GTM_ID=GTM-XXXXXXX

# API Keys
EGON_API_KEY=your_egon_api_key_here
EGON_API_URL=https://api.egon.de/v1

# Feature Flags
PUBLIC_ENABLE_PWA=true
PUBLIC_ENABLE_ANALYTICS=true
PUBLIC_MAINTENANCE_MODE=false

# Security
CSP_REPORT_URI=https://your-csp-report-endpoint.com

# Email (Optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password

# Development
NODE_ENV=development
PORT=4321
