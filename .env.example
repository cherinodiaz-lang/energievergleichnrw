# API Configuration
EGON_API_KEY=your_egon_api_key_here
EGON_API_URL=https://api.egon.de/v1

# Site Configuration
PUBLIC_SITE_URL=https://energievergleichnrw.de
PUBLIC_SITE_NAME=EnergieVergleich NRW

# Analytics
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
PUBLIC_GTM_ID=GTM-XXXXXXX

# Environment
NODE_ENV=development

# Security
SECRET_KEY=your_secret_key_here

# Email (Optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password_here

# Database (Optional)
DATABASE_URL=postgresql://user:password@localhost:5432/energievergleich

# Feature Flags
FEATURE_PWA_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_ERROR_REPORTING_ENABLED=true
